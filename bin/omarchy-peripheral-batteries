#!/usr/bin/env python3
"""Emit a single compact JSON line with the battery level of every peripheral
the bar cares about: keyboard, mouse, headset, earbuds (AirPods), etc.

Sources, in order of how the data is obtained:
  - Solaar      : live HID++ query for Logitech devices (mouse). Authoritative
                  over UPower, whose cached hidpp value freezes for ages.
  - UPower      : AirPods & any BT device that exposes a battery. Deduped by
                  serial. (UPower's hidpp value is only used when Solaar is
                  absent; its driver also mislabels the mouse kind, so KIND is
                  decided by model name here, not by the reported kind.)
  - HID feature : Aula F75 keyboard (Compx 2.4G receiver 3554:FA09). No standard
                  HID battery, but feature report 0x06 byte 3 holds the level
                  (validated against the keyboard's FN+B indicator). Needs hidraw
                  access (see 99-compx-kb-battery.rules).
  - headsetcontrol : gaming headsets the tool supports.
  - HID vendor  : HyperX Cloud III S Wireless (03f0:06be), queried over its
                  vendor protocol since headsetcontrol can't see it. Needs hidraw
                  access (see 99-hyperx-headset-battery.rules).

Output (one line, sorted): [{"kind","label","pct","charging"}, ...]
Empty array when nothing reports a battery.
"""

import json
import os
import re
import glob
import time
import fcntl
import select
import shutil
import subprocess

# ── classification ──────────────────────────────────────────────────────────
# (substring matched against the UPower model, case-insensitive) -> (kind, label)
MODEL_MAP = [
    ("pro x 2",  ("mouse",   "Mouse")),
    ("airpods",  ("earbuds", "AirPods")),
    ("hyperx",   ("headset", "HyperX")),
]
# bar ordering
KIND_ORDER = {"keyboard": 0, "mouse": 1, "headset": 2, "earbuds": 3, "other": 9}


def run(cmd, timeout=5):
    try:
        return subprocess.run(cmd, capture_output=True, text=True,
                              timeout=timeout).stdout
    except Exception:
        return ""


def classify(model, kind_hint):
    low = (model or "").lower()
    for needle, res in MODEL_MAP:
        if needle in low:
            return res
    if kind_hint in ("mouse", "keyboard", "headset", "headphones"):
        return ("headset" if kind_hint == "headphones" else kind_hint,
                model or kind_hint.title())
    return ("other", model or "Battery")


# ── UPower (mouse, AirPods, generic BT batteries) ─────────────────────────────
def upower_devices():
    paths = run(["upower", "-e"]).split()
    by_serial = {}
    out = []
    for path in paths:
        if "DisplayDevice" in path or "line_power" in path:
            continue
        info = run(["upower", "-i", path])
        if not info:
            continue
        fields = {}
        kind_hint = None
        for line in info.splitlines():
            m = re.match(r"\s*([a-z][\w-]*):\s+(.*)", line)
            if m:
                fields[m.group(1)] = m.group(2).strip()
            else:
                w = line.strip()
                if w in ("keyboard", "mouse", "headset", "headphones",
                         "battery", "phone", "gaming-input", "pen", "touchpad"):
                    kind_hint = w
        if fields.get("present", "yes") == "no":
            continue
        pct_raw = fields.get("percentage", "")
        if "should be ignored" in pct_raw:
            continue
        m = re.match(r"(\d+)", pct_raw)
        if not m:
            continue
        pct = int(m.group(1))
        state = fields.get("state", "").lower()
        if state == "unknown":
            continue
        charging = state in ("charging", "pending-charge", "fully-charged")
        model = fields.get("model", "")
        kind, label = classify(model, kind_hint)
        entry = {"kind": kind, "label": label, "pct": pct, "charging": charging}
        # dedupe by serial: the PRO X 2 shows up via both its dongle and USB.
        serial = fields.get("serial") or path
        prev = by_serial.get(serial)
        if prev is None or (charging and not prev["charging"]):
            by_serial[serial] = entry
    out.extend(by_serial.values())
    return out


# ── Keyboard: Compx 2.4G receiver feature report 0x06 ────────────────────────
def _ioc(d, t, nr, sz):
    return (d << 30) | (sz << 16) | (ord(t) << 8) | nr


def _hidiocgfeature(sz):
    return _ioc(3, "H", 0x07, sz)  # _IOC(WRITE|READ, 'H', 7, len)


def compx_keyboard():
    for hr in glob.glob("/sys/class/hidraw/hidraw*"):
        try:
            uevent = open(os.path.join(hr, "device", "uevent")).read().upper()
        except OSError:
            continue
        if "3554" not in uevent or "FA09" not in uevent:
            continue
        dev = "/dev/" + os.path.basename(hr)
        try:
            fd = os.open(dev, os.O_RDWR)
        except OSError:
            continue
        try:
            buf = bytearray(8)
            buf[0] = 0x06
            fcntl.ioctl(fd, _hidiocgfeature(8), buf, True)
            if buf[0] == 0x06:
                pct = buf[3]
                if 0 <= pct <= 100:
                    return {"kind": "keyboard", "label": "Teclado",
                            "pct": pct, "charging": False}
        except OSError:
            pass
        finally:
            os.close(fd)
    return None


# ── headsetcontrol (HyperX & friends) ────────────────────────────────────────
def headsetcontrol_devices():
    if not shutil.which("headsetcontrol"):
        return []
    out = run(["headsetcontrol", "-o", "json"])
    if not out:
        return []
    try:
        data = json.loads(out)
    except ValueError:
        return []
    res = []
    for dev in data.get("devices", []):
        bat = dev.get("battery", {})
        if bat.get("status") != "BATTERY_AVAILABLE":
            continue
        lvl = bat.get("level")
        if not isinstance(lvl, int) or not (0 <= lvl <= 100):
            continue
        name = dev.get("product") or dev.get("device") or "Headset"
        res.append({"kind": "headset", "label": name, "pct": lvl,
                    "charging": False})
    return res


# ── Solaar (live HID++ query for Logitech devices) ───────────────────────────
# The kernel/UPower only update the hidpp battery when the device *pushes* an
# event, so a charging mouse can sit frozen for ages. `solaar show` actively
# queries the device, giving a fresh level — so it takes priority for any kind
# it reports.
def solaar_devices():
    if not shutil.which("solaar"):
        return []
    try:
        out = subprocess.run(["solaar", "show"], capture_output=True,
                             text=True, timeout=20).stdout
    except Exception:
        return []
    res = []
    name = None
    kind = None
    seen_names = set()
    for line in out.splitlines():
        if line and not line[0].isspace():
            name, kind = line.strip(), None
            continue
        m = re.match(r"\s*Kind\s*:\s*(\w+)", line)
        if m:
            kind = m.group(1).lower()
            continue
        m = re.search(r"Battery:\s*(\d+)%,\s*(?:BatteryStatus\.)?(\w+)", line)
        if m and name and name not in seen_names:
            seen_names.add(name)
            pct = int(m.group(1))
            status = m.group(2).upper()
            k = {"mouse": "mouse", "keyboard": "keyboard",
                 "headset": "headset", "headphones": "headset",
                 "touchpad": "mouse"}.get(kind, "other")
            label = {"mouse": "Mouse", "keyboard": "Teclado"}.get(k, name)
            # "DISCHARGING" also contains "CHARG", so guard against it.
            charging = "CHARG" in status and "DISCHARG" not in status
            res.append({"kind": k, "label": label, "pct": pct,
                        "charging": charging})
    return res


# ── HyperX Cloud III S Wireless (vendor HID, headsetcontrol doesn't support it) ─
# Protocol reverse-engineered by auto94/HyperX-Cloud-2-Battery-Monitor: on the
# vendor interface (USB 03f0:06be) write [0c 02 03 01 00 06] padded to 52 bytes,
# read the reply, battery is byte 6. Off state replies 0xff (>100). Needs hidraw
# write access via udev rule 99-hyperx-headset-battery.rules.
def hyperx_headset():
    for hr in glob.glob("/sys/class/hidraw/hidraw*"):
        try:
            uevent = open(os.path.join(hr, "device", "uevent")).read().upper()
        except OSError:
            continue
        if "03F0" not in uevent or "06BE" not in uevent:
            continue
        dev = "/dev/" + os.path.basename(hr)
        try:
            fd = os.open(dev, os.O_RDWR | os.O_NONBLOCK)
        except OSError:
            return None  # no access yet (udev rule not applied)
        try:
            # drain any stale input reports so we read the reply to our query
            while select.select([fd], [], [], 0)[0]:
                try:
                    os.read(fd, 64)
                except OSError:
                    break
            cmd = bytes([0x0c, 0x02, 0x03, 0x01, 0x00, 0x06]) + bytes(46)
            os.write(fd, cmd)
            deadline = time.time() + 1.0
            while time.time() < deadline:
                if not select.select([fd], [], [], deadline - time.time())[0]:
                    break
                try:
                    data = os.read(fd, 64)
                except OSError:
                    break
                # Our reply echoes the request header; ignore unrelated reports.
                if len(data) >= 7 and data[:6] == cmd[:6]:
                    bat = data[6]   # 0xff (>100) when the headset is off
                    if 1 <= bat <= 100:
                        return {"kind": "headset", "label": "HyperX",
                                "pct": bat, "charging": False}
                    return None     # got our reply, headset is off → done
            return None
        except OSError:
            return None
        finally:
            os.close(fd)
    return None


def main():
    devs = []
    solaar = solaar_devices()
    devs.extend(solaar)
    # Solaar is authoritative for Logitech: it only yields a device when it gets
    # a *live* battery reading, so a disconnected/asleep mouse drops off instead
    # of lingering with a stale UPower value. When solaar is installed, never let
    # UPower contribute mouse/keyboard entries (those are the Logitech ones;
    # AirPods come through as "earbuds"/"headset" and are still allowed).
    exclude = {d["kind"] for d in solaar}
    if shutil.which("solaar"):
        exclude |= {"mouse", "keyboard"}
    devs.extend(d for d in upower_devices() if d["kind"] not in exclude)
    # Aula F75 keyboard on its Compx 2.4G receiver: battery is in HID feature
    # report 0x06, byte 3. Validated against the keyboard's own indicator
    # (FN+B): byte 3 = 0x64 = 100% matched all-keys-green. It just stays at 100%
    # for a long time because keyboards last weeks on a charge.
    kb = compx_keyboard()
    if kb:
        devs.append(kb)
    devs.extend(headsetcontrol_devices())
    # HyperX Cloud III S (its own vendor protocol; headsetcontrol can't see it).
    # Only if nothing else already reported a headset.
    if not any(d["kind"] == "headset" for d in devs):
        hx = hyperx_headset()
        if hx:
            devs.append(hx)

    # collapse duplicate kinds (e.g. headset from both UPower and headsetcontrol)
    seen = {}
    for d in devs:
        key = (d["kind"], d["label"])
        if key not in seen:
            seen[key] = d
    devs = list(seen.values())

    devs.sort(key=lambda d: (KIND_ORDER.get(d["kind"], 9), d["label"]))
    print(json.dumps(devs, separators=(",", ":")))


if __name__ == "__main__":
    main()
